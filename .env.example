# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token

# Timeweb Cloud API token (https://timeweb.cloud/my/api-keys)
TIMEWEB_API_TOKEN=your_timeweb_api_token

# Timeweb VPS server ID
SERVER_ID=123456

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USERS=111111111,222222222

# VPS SSH connection details
SSH_HOST=1.2.3.4
SSH_USER=root
SSH_PASSWORD=your_ssh_password

# Path to the Minecraft server directory on VPS
MINECRAFT_DIR=/opt/minecraft

# JVM memory settings
MINECRAFT_RAM_MAX=2G
MINECRAFT_RAM_MIN=1G

# Max seconds to wait for VPS to boot before giving up
VPS_BOOT_TIMEOUT=120
